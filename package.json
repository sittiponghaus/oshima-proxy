{
  "name": "oshima-proxy",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "source": "app/config/entrypoint.tsx",
  "scripts": {
    "prepare": "./cmd/prepare-effect.sh",
    "dev": "bun run build && wrangler dev",
    "build": "bun run build.ts",
    "deploy": "bun run build && wrangler deploy",
    "deploy:version": "bun run build && wrangler versions upload --tag \"$npm_package_version\"",
    "cf:typegen": "wrangler types",
    "fmt:write": "oxfmt --write \"**/*.{ts,tsx,js,jsx}\"",
    "fmt:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx}\"",
    "check:boundaries": "bun run cmd/check-boundaries.ts",
    "test": "vitest run",
    "test:unit": "vitest run shared server app",
    "test:integration": "vitest run test/integration",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.99",
    "@uidotdev/usehooks": "^2.4.1",
    "@vis.gl/react-maplibre": "^8.1.1",
    "effect": "^4.0.0-beta.99",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@effect/language-service": "^0.86.6",
    "@effect/vitest": "^4.0.0-beta.99",
    "@types/bun": "latest",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "^0.1.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tailwindcss": "^4.1.11",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
