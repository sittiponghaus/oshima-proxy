    "@vis.gl/react-maplibre": "^8.1.1",
    "effect": "^4.0.0-beta.99",
    "maplibre-gl": "^5.24.0",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.6",
    "@types/bun": "latest",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "^0.1.2",
    "oxfmt": "^0.58.0",
    "tailwindcss": "^4.1.11"
  }
