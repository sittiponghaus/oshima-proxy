{
  "name": "@snco/oshima-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot cmd/server.ts",
    "start": "NODE_ENV=production bun cmd/server.ts",
    "build": "bun run build.ts",
    "fmt:write": "oxfmt --write \"**/*.{ts,tsx,js,jsx}\"",
    "fmt:check": "oxfmt --check \"**/*.{ts,tsx,js,jsx}\""
  },
  "dependencies": {
    "@effect/atom-react": "4.0.0-beta.99",
    "@effect/opentelemetry": "^4.0.0-beta.99",
